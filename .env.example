# Local-only demo environment. Copy to .env (compose reads this).

# Postgres
POSTGRES_USER=vid
POSTGRES_PASSWORD=vidpass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Identity service
IDENTITY_DB=identity
JWT_ISSUER=vehicle-demo.identity-service
# Ed25519 keys are generated on startup if not provided (demo convenience).

# WebAuthn (real WebAuthn, RP ID = localhost)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Vehicle Identity Demo"
WEBAUTHN_RP_ORIGINS=http://localhost:5173

# Vehicle service
VEHICLE_DB=vehicle

# Audit service
AUDIT_DB=audit

# Simulated vehicle bootstrap (seeded credential)
SIM_VIN=VIN-DEMO-0001
SIM_BOOTSTRAP_SECRET=bootstrap-demo-secret

# Service URLs (in-compose DNS)
IDENTITY_URL=http://identity-service:8081
VEHICLE_URL=http://vehicle-service:8082
AUDIT_URL=http://audit-service:8083
